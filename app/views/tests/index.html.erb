<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test DISC — Profil comportemental</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300..700&display=swap" rel="stylesheet">

  <style>
    /* ===== DESIGN TOKENS ===== */
    :root, [data-theme="light"] {
      --color-bg:             #f7f6f2;
      --color-surface:        #f9f8f5;
      --color-surface-2:      #fbfbf9;
      --color-surface-offset: #f0ede8;
      --color-divider:        #dcd9d5;
      --color-border:         #d4d1ca;

      --color-text:           #28251d;
      --color-text-muted:     #6b6a65;
      --color-text-faint:     #b0afa9;
      --color-text-inverse:   #f9f8f4;

      --color-primary:        #01696f;
      --color-primary-hover:  #0c4e54;
      --color-primary-active: #0f3638;
      --color-primary-highlight: #d4e8e6;

      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
      --radius-xl: 1rem;
      --radius-full: 9999px;

      --shadow-sm: 0 1px 2px oklch(0.2 0.01 80 / 0.06);
      --shadow-md: 0 4px 12px oklch(0.2 0.01 80 / 0.08);
      --shadow-lg: 0 12px 32px oklch(0.2 0.01 80 / 0.12);

      --transition: 180ms cubic-bezier(0.16, 1, 0.3, 1);

      --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.875rem);
      --text-sm:   clamp(0.875rem, 0.8rem  + 0.35vw, 1rem);
      --text-base: clamp(1rem,     0.95rem + 0.25vw, 1.125rem);
      --text-lg:   clamp(1.125rem, 1rem    + 0.75vw, 1.5rem);
      --text-xl:   clamp(1.5rem,   1.2rem  + 1.25vw, 2.25rem);
      --text-2xl:  clamp(2rem,     1.2rem  + 2.5vw,  3.5rem);

      --font-display: 'Instrument Serif', Georgia, serif;
      --font-body: 'Inter', system-ui, sans-serif;

      --space-1:  0.25rem;
      --space-2:  0.5rem;
      --space-3:  0.75rem;
      --space-4:  1rem;
      --space-5:  1.25rem;
      --space-6:  1.5rem;
      --space-8:  2rem;
      --space-10: 2.5rem;
      --space-12: 3rem;
      --space-16: 4rem;
    }

    [data-theme="dark"] {
      --color-bg:             #171614;
      --color-surface:        #1c1b19;
      --color-surface-2:      #201f1d;
      --color-surface-offset: #22211f;
      --color-divider:        #262523;
      --color-border:         #393836;
      --color-text:           #cdccca;
      --color-text-muted:     #797876;
      --color-text-faint:     #5a5957;
      --color-text-inverse:   #2b2a28;
      --color-primary:        #4f98a3;
      --color-primary-hover:  #227f8b;
      --color-primary-active: #1a626b;
      --color-primary-highlight: #1e3535;
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.2);
      --shadow-md: 0 4px 12px oklch(0 0 0 / 0.3);
      --shadow-lg: 0 12px 32px oklch(0 0 0 / 0.4);
    }

    /* ===== BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      scroll-behavior: smooth;
      scroll-padding-top: var(--space-16);
    }
    body {
      min-height: 100dvh;
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      background-color: var(--color-bg);
      line-height: 1.6;
      transition: background-color var(--transition), color var(--transition);
    }
    img, svg { display: block; max-width: 100%; }
    button { cursor: pointer; background: none; border: none; font: inherit; color: inherit; }
    ::selection { background: oklch(from var(--color-primary) l c h / 0.18); color: var(--color-text); }
    :focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; border-radius: var(--radius-sm); }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* ===== LAYOUT ===== */
    .page-wrapper {
      min-height: 100dvh;
      display: grid;
      grid-template-rows: auto 1fr auto;
    }

    /* ===== NAV ===== */
    .site-nav {
      border-bottom: 1px solid oklch(from var(--color-text) l c h / 0.08);
      background: var(--color-surface);
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: blur(8px);
    }
    .nav-inner {
      max-width: 960px;
      margin-inline: auto;
      padding: var(--space-4) var(--space-6);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      text-decoration: none;
      color: var(--color-text);
    }
    .nav-logo-mark {
      width: 32px;
      height: 32px;
    }
    .nav-logo-text {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-text);
    }
    .nav-logo-text span {
      color: var(--color-primary);
    }
    .theme-toggle {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-text-muted);
      transition: background var(--transition), color var(--transition);
    }
    .theme-toggle:hover {
      background: var(--color-surface-offset);
      color: var(--color-text);
    }

    /* ===== MAIN ===== */
    .main-content {
      max-width: 960px;
      margin-inline: auto;
      padding: clamp(var(--space-10), 6vw, var(--space-16)) var(--space-6);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: center;
    }

    /* ===== LEFT COLUMN ===== */
    .hero-left {
      display: flex;
      flex-direction: column;
      gap: var(--space-8);
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      background: var(--color-primary-highlight);
      color: var(--color-primary);
      border: 1px solid oklch(from var(--color-primary) l c h / 0.2);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
      width: fit-content;
    }
    .hero-badge-dot {
      width: 6px;
      height: 6px;
      background: var(--color-primary);
      border-radius: 50%;
      animation: pulse-dot 2.4s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.85); }
    }

    .hero-heading {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--color-text);
    }
    .hero-heading em {
      font-style: italic;
      color: var(--color-primary);
    }
    .hero-description {
      font-size: var(--text-base);
      color: var(--color-text-muted);
      line-height: 1.7;
      max-width: 42ch;
    }

    .cta-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      background: var(--color-primary);
      color: var(--color-text-inverse);
      font-size: var(--text-sm);
      font-weight: 600;
      padding: var(--space-4) var(--space-8);
      border-radius: var(--radius-lg);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
      box-shadow: var(--shadow-sm);
      width: fit-content;
    }
    .btn-primary:hover {
      background: var(--color-primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px oklch(from var(--color-primary) l c h / 0.25);
    }
    .btn-primary:active {
      transform: translateY(0);
    }
    .btn-primary svg {
      display: inline;
      transition: transform var(--transition);
    }
    .btn-primary:hover svg {
      transform: translateX(3px);
    }

    .trust-line {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-text-faint);
    }
    .trust-line svg { flex-shrink: 0; }

    /* ===== RIGHT COLUMN — DISC CARD ===== */
    .hero-right {
      position: relative;
    }

    .disc-card {
      background: var(--color-surface);
      border: 1px solid oklch(from var(--color-text) l c h / 0.08);
      border-radius: var(--radius-xl);
      padding: var(--space-8);
      box-shadow: var(--shadow-lg);
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    .disc-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .disc-card-title {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--color-text-faint);
    }
    .disc-card-meta {
      font-size: var(--text-xs);
      color: var(--color-text-faint);
      display: flex;
      align-items: center;
      gap: var(--space-1);
    }

    .disc-quadrant {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }
    .disc-item {
      background: var(--color-bg);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      border-radius: var(--radius-lg);
      padding: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      transition: box-shadow var(--transition), border-color var(--transition);
      cursor: default;
    }
    .disc-item:hover {
      box-shadow: var(--shadow-md);
      border-color: oklch(from var(--color-text) l c h / 0.14);
    }
    .disc-item-letter {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: 400;
      line-height: 1;
    }
    .disc-item-name {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--color-text-muted);
    }
    .disc-item-desc {
      font-size: var(--text-xs);
      color: var(--color-text-faint);
      line-height: 1.5;
    }
    .disc-bar-wrap {
      margin-top: var(--space-1);
      height: 3px;
      background: var(--color-surface-offset);
      border-radius: var(--radius-full);
      overflow: hidden;
    }
    .disc-bar {
      height: 100%;
      border-radius: var(--radius-full);
      opacity: 0.7;
    }

    /* D = red-orange, I = amber, S = teal, C = blue */
    .disc-d .disc-item-letter { color: #b84c2e; }
    .disc-d .disc-bar { background: #b84c2e; width: 82%; }
    .disc-i .disc-item-letter { color: #c07830; }
    .disc-i .disc-bar { background: #c07830; width: 68%; }
    .disc-s .disc-item-letter { color: var(--color-primary); }
    .disc-s .disc-bar { background: var(--color-primary); width: 74%; }
    .disc-c .disc-item-letter { color: #3a6ca8; }
    .disc-c .disc-bar { background: #3a6ca8; width: 60%; }

    /* ===== STATS ROW ===== */
    .stats-row {
      display: flex;
      gap: var(--space-4);
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-divider);
    }
    .stat-item {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }
    .stat-value {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 400;
      color: var(--color-text);
      line-height: 1;
    }
    .stat-label {
      font-size: var(--text-xs);
      color: var(--color-text-faint);
      line-height: 1.3;
    }
    .stat-divider {
      width: 1px;
      background: var(--color-divider);
      align-self: stretch;
    }

    /* ===== BENEFIT PILLS ===== */
    .benefits-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }
    .benefit-pill {
      display: inline-flex;
      align-items: center;
      gap: var(--space-1);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      background: var(--color-surface-offset);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
    }
    .benefit-pill svg {
      color: var(--color-primary);
    }

    /* ===== FOOTER ===== */
    .site-footer {
      border-top: 1px solid oklch(from var(--color-text) l c h / 0.08);
      padding: var(--space-6);
    }
   .footer-inner {
  max-width: 960px;
  margin-inline: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: var(--text-xs);
  color: var(--color-text-faint);
  gap: var(--space-2);
}

    /* ===== SCROLL REVEALS ===== */
    .fade-in { opacity: 1; }
    @supports (animation-timeline: scroll()) {
      .fade-in {
        opacity: 0;
        animation: reveal-fade linear both;
        animation-timeline: view();
        animation-range: entry 0% entry 80%;
      }
    }
    @keyframes reveal-fade { to { opacity: 1; } }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .main-content {
        grid-template-columns: 1fr;
        gap: var(--space-10);
      }
      .hero-right {
        order: -1;
      }
      .disc-quadrant {
        grid-template-columns: 1fr 1fr;
      }
      .stats-row {
        gap: var(--space-3);
      }
    }

    @media (max-width: 480px) {
      .disc-card {
        padding: var(--space-5);
      }
      .disc-quadrant {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-2);
      }
      .footer-inner {
        justify-content: center;
        text-align: center;
      }
    }
  </style>
</head>
<body>

<div class="page-wrapper">

  <!-- NAV -->
  <nav class="site-nav" aria-label="Navigation principale">
    <div class="nav-inner">
      <a href="#" class="nav-logo" aria-label="Accueil DISC">
        <!-- SVG Logo mark: stylized D letter in circle -->
        <svg class="nav-logo-mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
          <path d="M10 9h5.5C18.538 9 21 11.462 21 16c0 4.538-2.462 7-5.5 7H10V9Z" fill="var(--color-primary)" opacity="0.9"/>
          <path d="M13 12.5h2.2c1.82 0 3.3 1.568 3.3 3.5s-1.48 3.5-3.3 3.5H13v-7Z" fill="var(--color-surface)" opacity="0.85"/>
        </svg>
        <span class="nav-logo-text">disc<span>profile</span></span>
      </a>
      <button
        class="theme-toggle"
        data-theme-toggle
        aria-label="Basculer le thème"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- MAIN -->
  <main>
    <div class="main-content">

      <!-- LEFT: HERO TEXT -->
      <div class="hero-left">

        <div class="hero-badge fade-in">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          Méthodologie reconnue mondialement
        </div>

        <h1 class="hero-heading fade-in">
          Découvrez votre<br>
          <em>profil DISC</em>
        </h1>

        <p class="hero-description fade-in">
          Un questionnaire comportemental conçu pour révéler vos forces naturelles, votre style de communication et vos leviers de performance professionnelle.
        </p>

        <div class="benefits-row fade-in">
          <span class="benefit-pill">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Forces naturelles
          </span>
          <span class="benefit-pill">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Style de communication
          </span>
          <span class="benefit-pill">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Relations professionnelles
          </span>
        </div>

        <div class="cta-group fade-in">
         <%= link_to test_path(1), class: "btn-primary" do %>
  Commencer le test
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path d="M5 12h14M12 5l7 7-7 7"/>
  </svg>
<% end %>

          <div class="trust-line">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Anonyme · Gratuit · Sans inscription
          </div>
        </div>

      </div>

      <!-- RIGHT: DISC PREVIEW CARD -->
      <div class="hero-right fade-in" aria-hidden="true">
        <div class="disc-card">

          <div class="disc-card-header">
            <span class="disc-card-title">Votre profil comportemental</span>
            <span class="disc-card-meta">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              ~10 min
            </span>
          </div>

          <div class="disc-quadrant">
            <div class="disc-item disc-d">
              <span class="disc-item-letter">D</span>
              <span class="disc-item-name">Dominant</span>
              <span class="disc-item-desc">Orienté résultats, direct, décisif</span>
              <div class="disc-bar-wrap"><div class="disc-bar"></div></div>
            </div>
            <div class="disc-item disc-i">
              <span class="disc-item-letter">I</span>
              <span class="disc-item-name">Influent</span>
              <span class="disc-item-desc">Communicatif, enthousiaste, convaincant</span>
              <div class="disc-bar-wrap"><div class="disc-bar"></div></div>
            </div>
            <div class="disc-item disc-s">
              <span class="disc-item-letter">S</span>
              <span class="disc-item-name">Stable</span>
              <span class="disc-item-desc">Patient, loyal, orienté équipe</span>
              <div class="disc-bar-wrap"><div class="disc-bar"></div></div>
            </div>
            <div class="disc-item disc-c">
              <span class="disc-item-letter">C</span>
              <span class="disc-item-name">Consciencieux</span>
              <span class="disc-item-desc">Analytique, méthodique, précis</span>
              <div class="disc-bar-wrap"><div class="disc-bar"></div></div>
            </div>
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-value">4</span>
              <span class="stat-label">Styles<br>comportementaux</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value">28</span>
              <span class="stat-label">Questions<br>ciblées</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Gratuit &amp;<br>confidentiel</span>
            </div>
          </div>

        </div>
      </div>

    </div>
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span>Basé sur la méthodologie DISC — William Moulton Marston, 1928</span>
      <span>© <%= Time.now.year %> ANDRAMIARISON Mandaniaina Precieux </span>
    </div>
  </footer>

</div>

<!-- Theme toggle script -->
<script>
(function(){
  const toggle = document.querySelector('[data-theme-toggle]');
  const root = document.documentElement;
  let current = root.getAttribute('data-theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  root.setAttribute('data-theme', current);

  const moonIcon = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  const sunIcon  = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';

  function updateIcon() {
    if (toggle) {
      toggle.innerHTML = current === 'dark' ? sunIcon : moonIcon;
      toggle.setAttribute('aria-label', 'Basculer vers le mode ' + (current === 'dark' ? 'clair' : 'sombre'));
    }
  }
  updateIcon();

  if (toggle) {
    toggle.addEventListener('click', () => {
      current = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', current);
      updateIcon();
    });
  }
})();
</script>

</body>
</html>