<h1>Votre résultat DISC</h1>

<h2>Profil principal : <%= @primary_type %></h2>

<h2>Profil secondaire : <%= @secondary_type %></h2>

<h3>Scores</h3>

<ul>
  <li>Dominant : <%= @scores["D"] %></li>
  <li>Influent : <%= @scores["I"] %></li>
  <li>Stable : <%= @scores["S"] %></li>
  <li>Consciencieux : <%= @scores["C"] %></li>
</ul>

<% if @profile %>
  <h2><%= @profile.name %></h2>

  <p>
    <strong>Description :</strong>
    <%= @profile.description %>
  </p>

  <p>
    <strong>Forces :</strong>
    <%= @profile.strengths %>
  </p>

  <p>
    <strong>Faiblesses :</strong>
    <%= @profile.weaknesses %>
  </p>

  <p>
    <strong>Conseils :</strong>
    <%= @profile.advice %>
  </p>

  <p>
    <strong>Métiers adaptés :</strong>
    <%= @profile.careers %>
  </p>
<% end %>

<%= link_to "Refaire le test", root_path %>