<%# ============================================================
    Vue : Résultat du test DISC
    Variables : @primary_name, @secondary_name, @primary_type,
                @secondary_type, @profile_gradient, @scores,
                @profile (name, description, strengths,
                weaknesses, advice, careers)
    ============================================================ %>

<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Votre profil DISC — <%= @primary_name %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300..700&display=swap" rel="stylesheet">

  <style>
    /* ===== DESIGN TOKENS ===== */
    :root, [data-theme="light"] {
      --color-bg:               #f7f6f2;
      --color-surface:          #f9f8f5;
      --color-surface-2:        #fbfbf9;
      --color-surface-offset:   #f0ede8;
      --color-surface-dynamic:  #e6e4df;
      --color-divider:          #dcd9d5;
      --color-border:           #d4d1ca;

      --color-text:             #28251d;
      --color-text-muted:       #6b6a65;
      --color-text-faint:       #b0afa9;
      --color-text-inverse:     #f9f8f4;

      --color-primary:          #01696f;
      --color-primary-hover:    #0c4e54;
      --color-primary-highlight:#d4e8e6;

      /* Couleurs DISC */
      --disc-d:        #b84c2e;
      --disc-d-light:  #f5e8e4;
      --disc-i:        #c07830;
      --disc-i-light:  #f5eddf;
      --disc-s:        #01696f;
      --disc-s-light:  #d4e8e6;
      --disc-c:        #3a6ca8;
      --disc-c-light:  #dce8f4;

      --radius-sm:   0.375rem;
      --radius-md:   0.5rem;
      --radius-lg:   0.75rem;
      --radius-xl:   1rem;
      --radius-2xl:  1.5rem;
      --radius-full: 9999px;

      --shadow-sm: 0 1px 2px oklch(0.2 0.01 80 / 0.06);
      --shadow-md: 0 4px 12px oklch(0.2 0.01 80 / 0.08);
      --shadow-lg: 0 16px 40px oklch(0.2 0.01 80 / 0.10);

      --transition: 180ms cubic-bezier(0.16, 1, 0.3, 1);

      --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.875rem);
      --text-sm:   clamp(0.875rem, 0.8rem  + 0.35vw, 1rem);
      --text-base: clamp(1rem,     0.95rem + 0.25vw, 1.125rem);
      --text-lg:   clamp(1.125rem, 1rem    + 0.75vw, 1.5rem);
      --text-xl:   clamp(1.5rem,   1.2rem  + 1.25vw, 2.25rem);

      --font-display: 'Instrument Serif', Georgia, serif;
      --font-body:    'Inter', system-ui, sans-serif;

      --space-1:  0.25rem;
      --space-2:  0.5rem;
      --space-3:  0.75rem;
      --space-4:  1rem;
      --space-5:  1.25rem;
      --space-6:  1.5rem;
      --space-8:  2rem;
      --space-10: 2.5rem;
      --space-12: 3rem;
      --space-16: 4rem;

      --content-narrow: 640px;
    }

    [data-theme="dark"] {
      --color-bg:               #171614;
      --color-surface:          #1c1b19;
      --color-surface-2:        #201f1d;
      --color-surface-offset:   #22211f;
      --color-surface-dynamic:  #2d2c2a;
      --color-divider:          #262523;
      --color-border:           #393836;
      --color-text:             #cdccca;
      --color-text-muted:       #797876;
      --color-text-faint:       #5a5957;
      --color-text-inverse:     #2b2a28;
      --color-primary:          #4f98a3;
      --color-primary-hover:    #227f8b;
      --color-primary-highlight:#1e3535;
      --disc-d:        #e0705a;
      --disc-d-light:  #2e1f1a;
      --disc-i:        #dfa060;
      --disc-i-light:  #2b211a;
      --disc-s:        #4f98a3;
      --disc-s-light:  #1a2e30;
      --disc-c:        #6b9fd4;
      --disc-c-light:  #1a2535;
      --shadow-sm: 0 1px 2px oklch(0 0 0 / 0.25);
      --shadow-md: 0 4px 12px oklch(0 0 0 / 0.35);
      --shadow-lg: 0 16px 40px oklch(0 0 0 / 0.45);
    }

    /* ===== BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
    body {
      min-height: 100dvh;
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--color-text);
      background: var(--color-bg);
      line-height: 1.6;
      transition: background-color var(--transition), color var(--transition);
    }
    img, svg { display: block; max-width: 100%; }
    button { cursor: pointer; background: none; border: none; font: inherit; color: inherit; }
    ::selection { background: oklch(from var(--color-primary) l c h / 0.18); }
    :focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; border-radius: var(--radius-sm); }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
    }

    /* ===== PAGE LAYOUT ===== */
    .page {
      max-width: var(--content-narrow);
      margin-inline: auto;
      padding: clamp(var(--space-8), 5vw, var(--space-12)) var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    /* ===== TOP BAR ===== */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .topbar-logo {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      text-decoration: none;
      color: var(--color-text);
    }
    .topbar-logo-text {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 400;
      letter-spacing: -0.01em;
    }
    .topbar-logo-text span { color: var(--color-primary); }
    .theme-toggle {
      width: 34px; height: 34px;
      border-radius: var(--radius-md);
      display: flex; align-items: center; justify-content: center;
      color: var(--color-text-muted);
      transition: background var(--transition), color var(--transition);
    }
    .theme-toggle:hover { background: var(--color-surface-offset); color: var(--color-text); }

    /* ===== HERO RÉSULTAT ===== */
    .result-hero {
      background: var(--color-surface);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      border-radius: var(--radius-2xl);
      padding: clamp(var(--space-8), 5vw, var(--space-10));
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-5);
      text-align: center;
      box-shadow: var(--shadow-lg);
      position: relative;
      overflow: hidden;
    }

    /* Accent décoratif discret en haut */
    .result-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: var(--color-primary);
      border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
    }

    .result-badge {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      background: var(--color-primary-highlight);
      color: var(--color-primary);
      border: 1px solid oklch(from var(--color-primary) l c h / 0.2);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
    }

    .result-eyebrow {
      font-size: var(--text-sm);
      color: var(--color-text-muted);
      font-weight: 400;
    }

    .result-name {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: 400;
      letter-spacing: -0.02em;
      color: var(--color-text);
      line-height: 1.15;
    }

    .result-combo {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.05em;
      color: var(--color-text-faint);
      text-transform: uppercase;
      padding: var(--space-1) var(--space-3);
      border: 1px solid oklch(from var(--color-text) l c h / 0.1);
      border-radius: var(--radius-full);
      background: var(--color-surface-offset);
    }

    /* ===== PROFILS GRID ===== */
    .profiles-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }

    .profile-card {
      background: var(--color-surface);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      border-radius: var(--radius-xl);
      padding: var(--space-5);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .profile-card-label {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-text-faint);
    }

    .profile-card-value {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 400;
      color: var(--color-text);
      line-height: 1.2;
    }

    .profile-card-sub {
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }

    /* ===== SCORES ===== */
    .scores-section {
      background: var(--color-surface);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .section-title {
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--color-text-faint);
    }

    .score-row {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .score-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .score-label {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      font-size: var(--text-sm);
      font-weight: 500;
      color: var(--color-text);
    }

    .score-letter {
      width: 22px;
      height: 22px;
      border-radius: var(--radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: var(--text-sm);
      font-weight: 400;
      flex-shrink: 0;
    }

    .score-value {
      font-size: var(--text-sm);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
      color: var(--color-text-muted);
    }

    .score-track {
      height: 6px;
      background: var(--color-surface-dynamic);
      border-radius: var(--radius-full);
      overflow: hidden;
    }

    .score-fill {
      height: 100%;
      border-radius: var(--radius-full);
      transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Couleurs par dimension */
    .disc-d-letter { background: var(--disc-d-light); color: var(--disc-d); }
    .disc-i-letter { background: var(--disc-i-light); color: var(--disc-i); }
    .disc-s-letter { background: var(--disc-s-light); color: var(--disc-s); }
    .disc-c-letter { background: var(--disc-c-light); color: var(--disc-c); }

    .disc-d-bar { background: var(--disc-d); }
    .disc-i-bar { background: var(--disc-i); }
    .disc-s-bar { background: var(--disc-s); }
    .disc-c-bar { background: var(--disc-c); }

    /* ===== PROFIL DÉTAILLÉ ===== */
    .profile-detail {
      background: var(--color-surface);
      border: 1px solid oklch(from var(--color-text) l c h / 0.07);
      border-radius: var(--radius-xl);
      overflow: hidden;
    }

    .profile-detail-header {
      padding: var(--space-6);
      border-bottom: 1px solid var(--color-divider);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .profile-detail-name {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--color-text);
      line-height: 1.2;
    }

    .profile-detail-body {
      padding: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
    }

    .detail-block {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .detail-block-title {
      font-size: var(--text-xs);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-primary);
    }

    .detail-block-text {
      font-size: var(--text-base);
      color: var(--color-text-muted);
      line-height: 1.7;
      max-width: 60ch;
    }

    .detail-divider {
      height: 1px;
      background: var(--color-divider);
    }

    /* ===== CTA ===== */
    .cta-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-4);
      padding-top: var(--space-2);
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      background: var(--color-primary);
      color: var(--color-text-inverse);
      font-size: var(--text-sm);
      font-weight: 600;
      padding: var(--space-4) var(--space-8);
      border-radius: var(--radius-lg);
      text-decoration: none;
      letter-spacing: 0.01em;
      box-shadow: var(--shadow-sm);
      transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    }
    .btn-primary:hover {
      background: var(--color-primary-hover);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px oklch(from var(--color-primary) l c h / 0.28);
    }
    .btn-primary:active { transform: translateY(0); }
    .btn-primary svg { transition: transform var(--transition); }
    .btn-primary:hover svg { transform: translateX(-3px); }

    .cta-note {
      font-size: var(--text-xs);
      color: var(--color-text-faint);
      text-align: center;
    }

    /* ===== FOOTER ===== */
    .page-footer {
      font-size: var(--text-xs);
      color: var(--color-text-faint);
      text-align: center;
      padding-bottom: var(--space-4);
       display: flex;
  justify-content: center;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
      
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .profiles-grid { grid-template-columns: 1fr; }
      .result-hero { padding: var(--space-6); }
      .scores-section, .profile-detail-header, .profile-detail-body { padding: var(--space-5); }
    }
  </style>
</head>

<body>
<main class="page">

  <!-- TOP BAR -->
  <header class="topbar">
    <%= link_to root_path, class: "topbar-logo", aria: { label: "Retour à l'accueil" } do %>
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.5" opacity="0.15"/>
        <path d="M10 9h5.5C18.538 9 21 11.462 21 16c0 4.538-2.462 7-5.5 7H10V9Z" fill="currentColor" opacity="0.85"/>
        <path d="M13 12.5h2.2c1.82 0 3.3 1.568 3.3 3.5s-1.48 3.5-3.3 3.5H13v-7Z" fill="var(--color-surface)" opacity="0.9"/>
      </svg>
      <span class="topbar-logo-text">disc<span>profile</span></span>
    <% end %>
    <button class="theme-toggle" data-theme-toggle aria-label="Basculer le thème" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </header>

  <!-- HERO RÉSULTAT -->
  <section class="result-hero" aria-labelledby="result-heading">
    <span class="result-badge">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Résultat du test
    </span>
    <p class="result-eyebrow">Votre personnalité dominante est</p>
    <h1 class="result-name" id="result-heading"><%= @primary_name %></h1>
    <span class="result-combo">
      Profil combiné &nbsp;·&nbsp; <%= @primary_type %>–<%= @secondary_type %>
    </span>
  </section>

  <!-- PROFILS PRINCIPAL / SECONDAIRE -->
  <div class="profiles-grid" aria-label="Profils DISC">
    <div class="profile-card">
      <span class="profile-card-label">Profil principal</span>
      <span class="profile-card-value"><%= @primary_name %></span>
      <span class="profile-card-sub">Dimension <%= @primary_type %></span>
    </div>
    <div class="profile-card">
      <span class="profile-card-label">Profil secondaire</span>
      <span class="profile-card-value"><%= @secondary_name %></span>
      <span class="profile-card-sub">Dimension <%= @secondary_type %></span>
    </div>
  </div>

  <!-- SCORES AVEC BARRES -->
  <section class="scores-section" aria-labelledby="scores-title">
    <h2 class="section-title" id="scores-title">Scores par dimension</h2>

    <div class="score-row">
      <div class="score-meta">
        <span class="score-label">
          <span class="score-letter disc-d-letter">D</span>
          Dominant
        </span>
        <span class="score-value"><%= @scores["D"] %></span>
      </div>
      <div class="score-track">
        <div class="score-fill disc-d-bar"
             style="width: <%= [(@scores["D"].to_f / 28 * 100).round, 100].min %>%"></div>
      </div>
    </div>

    <div class="score-row">
      <div class="score-meta">
        <span class="score-label">
          <span class="score-letter disc-i-letter">I</span>
          Influent
        </span>
        <span class="score-value"><%= @scores["I"] %></span>
      </div>
      <div class="score-track">
        <div class="score-fill disc-i-bar"
             style="width: <%= [(@scores["I"].to_f / 28 * 100).round, 100].min %>%"></div>
      </div>
    </div>

    <div class="score-row">
      <div class="score-meta">
        <span class="score-label">
          <span class="score-letter disc-s-letter">S</span>
          Stable
        </span>
        <span class="score-value"><%= @scores["S"] %></span>
      </div>
      <div class="score-track">
        <div class="score-fill disc-s-bar"
             style="width: <%= [(@scores["S"].to_f / 28 * 100).round, 100].min %>%"></div>
      </div>
    </div>

    <div class="score-row">
      <div class="score-meta">
        <span class="score-label">
          <span class="score-letter disc-c-letter">C</span>
          Consciencieux
        </span>
        <span class="score-value"><%= @scores["C"] %></span>
      </div>
      <div class="score-track">
        <div class="score-fill disc-c-bar"
             style="width: <%= [(@scores["C"].to_f / 28 * 100).round, 100].min %>%"></div>
      </div>
    </div>
  </section>

  <!-- PROFIL DÉTAILLÉ -->
  <% if @profile %>
    <section class="profile-detail" aria-labelledby="profile-name">

      <div class="profile-detail-header">
        <span class="section-title">Analyse de votre profil</span>
        <h2 class="profile-detail-name" id="profile-name"><%= @profile.name %></h2>
      </div>

      <div class="profile-detail-body">

        <div class="detail-block">
          <span class="detail-block-title">Description</span>
          <p class="detail-block-text"><%= @profile.description %></p>
        </div>

        <div class="detail-divider" aria-hidden="true"></div>

        <div class="detail-block">
          <span class="detail-block-title">Forces</span>
          <p class="detail-block-text"><%= @profile.strengths %></p>
        </div>

        <div class="detail-divider" aria-hidden="true"></div>

        <div class="detail-block">
          <span class="detail-block-title">Axes de développement</span>
          <p class="detail-block-text"><%= @profile.weaknesses %></p>
        </div>

        <div class="detail-divider" aria-hidden="true"></div>

        <div class="detail-block">
          <span class="detail-block-title">Conseils</span>
          <p class="detail-block-text"><%= @profile.advice %></p>
        </div>

        <div class="detail-divider" aria-hidden="true"></div>

        <div class="detail-block">
          <span class="detail-block-title">Métiers adaptés</span>
          <p class="detail-block-text"><%= @profile.careers %></p>
        </div>

      </div>
    </section>
  <% end %>

  <!-- CTA -->
  <div class="cta-section">
    <%= link_to root_path, class: "btn-primary" do %>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
      Refaire le test
    <% end %>
    <p class="cta-note">Vos résultats ne sont pas enregistrés — anonyme &amp; confidentiel</p>
  </div>

  <footer class="page-footer">
    Test de personnalité DISC — Basé sur la méthodologie de William Moulton Marston
     <span>© <%= Time.now.year %> ANDRAMIARISON Mandaniaina Precieux </span>
  </footer>

</main>

<!-- ===== SCRIPTS ===== -->
<script>
/* Thème clair / sombre */
(function(){
  const toggle = document.querySelector('[data-theme-toggle]');
  const root   = document.documentElement;
  let current  = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  root.setAttribute('data-theme', current);
  const moonSVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
  const sunSVG  = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
  function applyIcon() {
    if (!toggle) return;
    toggle.innerHTML = current === 'dark' ? sunSVG : moonSVG;
    toggle.setAttribute('aria-label', 'Basculer vers le mode ' + (current === 'dark' ? 'clair' : 'sombre'));
  }
  applyIcon();
  if (toggle) {
    toggle.addEventListener('click', () => {
      current = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', current);
      applyIcon();
    });
  }
})();

/* Animation des barres de score au chargement */
(function(){
  const fills = document.querySelectorAll('.score-fill');
  fills.forEach(el => {
    const target = el.style.width;
    el.style.width = '0%';
    requestAnimationFrame(() => {
      setTimeout(() => { el.style.width = target; }, 120);
    });
  });
})();
</script>

</body>
</html>